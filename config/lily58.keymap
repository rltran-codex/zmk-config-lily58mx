#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>

#define default_layer 0
#define lower_layer 1
#define raise_layer 2
#define adjust_layer 3
#define extra_layer 4

/ {
    behaviors {
        hm: homerow_mods {
            compatible = "zmk,behavior-hold-tap";
            label = "HOMEROW_MODS";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <300>;
            quick-tap-ms = <200>;
            require-prior-idle-ms = <90>;
            flavor = "balanced";
        };

        hm_shift_l: hm_shift_l {
            compatible = "zmk,behavior-hold-tap";
            label = "HM_SHIFT_L";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <190>;
            quick-tap-ms = <150>;
            require-prior-idle-ms = <100>;
            flavor = "tap-preferred";
        };

        hm_shift_r: hm_shift_r {
            compatible = "zmk,behavior-hold-tap";
            label = "HM_SHIFT_R";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <190>;
            quick-tap-ms = <150>;
            require-prior-idle-ms = <100>;
            flavor = "tap-preferred";
        };
    };

    combos {
        compatible = "zmk,combos";

        esc {
            bindings = <&kp ESCAPE>;
            key-positions = <42 43 53 54>;
        };

        bth_clear {
            bindings = <&bt BT_CLR>;
            key-positions = <50 51 52 53 54 55 56 57>;
        };
    };

    macros {
        clip_history: clip_history {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LEFT_WIN>,
                <&macro_tap>,
                <&kp V>,
                <&macro_release>,
                <&kp LEFT_WIN>;

            label = "CLIP_HISTORY";
        };

        vs_left_editor: vs_left_editor {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LCTRL>,
                <&macro_tap>,
                <&kp K>,
                <&macro_tap>,
                <&kp LEFT_ARROW>,
                <&macro_release>,
                <&kp LEFT_CONTROL>;

            label = "VS_LEFT_EDITOR";
        };

        vs_right_editor: vs_right_editor {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LCTRL>,
                <&macro_tap>,
                <&kp K>,
                <&macro_tap>,
                <&kp RIGHT>,
                <&macro_release>,
                <&kp LEFT_CONTROL>;

            label = "VS_RIGHT_EDITOR";
        };

        vs_fold: vs_fold {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LCTRL &kp LEFT_SHIFT>,
                <&macro_tap>,
                <&kp LEFT_BRACKET>,
                <&macro_release>,
                <&kp LEFT_CONTROL &kp LEFT_SHIFT>;

            label = "VS_FOLD";
        };

        vs_unfold: vs_unfold {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LCTRL &kp LEFT_SHIFT>,
                <&macro_tap>,
                <&kp RIGHT_BRACKET>,
                <&macro_release>,
                <&kp LEFT_CONTROL &kp LEFT_SHIFT>;

            label = "VS_UNFOLD";
        };

        snippet_tool: snippet_tool {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LEFT_WIN &kp LEFT_SHIFT>,
                <&macro_tap>,
                <&kp S>,
                <&macro_release>,
                <&kp LEFT_WIN &kp LEFT_SHIFT>;

            label = "SNIPPET_TOOL";
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            display-name = "BASE";

            // ------------------------------------------------------------------------------------------------------------
            // |  ESC  |  1  |  2  |  3   |  4   |  5   |                   |  6   |  7    |  8    |  9   |   0   |   `   |
            // |  TAB  |  Q  |  W  |  E   |  R   |  T   |                   |  Y   |  U    |  I    |  O   |   P   |   -   |
            // |  CTRL |  A  |  S  |  D   |  F   |  G   |                   |  H   |  J    |  K    |  L   |   ;   |   '   |
            // | SHIFT |  Z  |  X  |  C   |  V   |  B   |   "["  |  |  "]"  |  N   |  M    |  ,    |  .   |   /   | SHIFT |
            //                     | ALT  | GUI  | LOWER|  SPACE |  | ENTER | RAISE| BSPC  | GUI   |

            bindings = <
&kp ESC           &kp N1          &kp N2          &kp N3                    &kp N4              &kp N5                               &kp N6         &kp N7               &kp N8                     &kp N9           &kp N0               &kp MINUS
&kp CAPS          &kp Q           &kp W           &kp E                     &kp R               &kp T                                &kp Y          &kp U                &kp I                      &kp O            &kp P                &kp NON_US_BACKSLASH
&kp TAB           &kp A           &hm LEFT_ALT S  &hm_shift_l LEFT_SHIFT D  &hm LEFT_CONTROL F  &kp G                                &kp H          &hm RIGHT_CONTROL J  &hm_shift_r RIGHT_SHIFT K  &hm RIGHT_ALT L  &kp SEMI             &kp SQT
&kp LEFT_CONTROL  &hm LEFT_WIN Z  &kp X           &kp C                     &kp V               &kp B   &kp LBKT       &kp RBKT      &kp N          &kp M                &kp COMMA                  &kp DOT          &hm RIGHT_WIN SLASH  &kp RSHFT
                                                  &kp LALT                  &kp LGUI            &mo 4   &lt 1 SPACE    &lt 2 RETURN  &kp BACKSPACE  &kp RIGHT_ALT        &kp RGUI
            >;
        };

        nav_layer {
            display-name = "NAV";

            // ------------------------------------------------------------------------------------------------------------
            // |       |     |     |      |      |      |                   |      |       |       |      |       |       |
            // |   `   |  1  |  2  |  3   |  4   |  5   |                   |  6   |   7   |   8   |  9   |   0   |       |
            // |   F1  |  F2 |  F3 |  F4  |  F5  |  F6  |                   |      |   <-  |   v   |  ^   |  ->   |       |
            // |   F7  |  F8 |  F9 |  F10 |  F11 |  F12 |        |  |       |  +   |   -   |   =   |  [   |   ]   |   \   |
            //                     |      |      |      |        |  |       |      |       |       |

            bindings = <
&trans  &trans  &trans       &trans    &trans         &trans                     &none   &none                       &none                             &none                   &kp NUMBER_0  &trans
&trans  &trans  &kp PAGE_UP  &kp UP    &kp PAGE_DOWN  &trans                     &none   &kp NUMBER_7                &kp NUMBER_8                      &kp N9                  &none         &trans
&trans  &trans  &kp LEFT     &kp DOWN  &kp RIGHT      &trans                     &none   &hm RIGHT_CONTROL NUMBER_4  &hm_shift_r RIGHT_SHIFT NUMBER_5  &hm RIGHT_ALT NUMBER_6  &none         &trans
&trans  &trans  &trans       &trans    &kp HOME       &kp END  &trans    &trans  &trans  &kp NUMBER_1                &kp NUMBER_2                      &kp NUMBER_3            &trans        &trans
                             &trans    &trans         &trans   &trans    &trans  &trans  &kp DEL                     &trans
            >;
        };

        symbol {
            bindings = <
&kp GRAVE  &kp EXCLAMATION  &kp AT_SIGN  &kp HASH                      &kp DOLLAR  &kp PERCENT                                       &kp CARET  &kp AMPERSAND  &kp ASTERISK                   &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS  &kp MINUS
&kp TILDE  &none            &none        &trans                        &none       &none                                             &none      &none          &trans                         &none                 &none                  &trans
&trans     &trans           &trans       &hm_shift_l LEFT_SHIFT UNDER  &trans      &kp MINUS                                         &kp PLUS   &trans         &hm_shift_r RIGHT_SHIFT COLON  &trans                &trans                 &trans
&trans     &trans           &trans       &kp COMMA                     &trans      &trans         &kp LEFT_BRACE    &kp RIGHT_BRACE  &trans     &trans         &kp EQUAL                      &trans                &trans                 &trans
                                         &trans                        &trans      &kp BACKSPACE  &trans            &trans           &trans     &trans         &trans
            >;

            label = "SYM";
        };

        system {
            bindings = <
&trans      &kp F1        &kp F2        &kp F3        &kp F4        &kp F5                          &kp F6      &kp F7             &kp F8           &kp F9  &kp F10  &kp F11
&trans      &trans        &trans        &trans        &trans        &trans                          &trans      &trans             &trans           &trans  &trans   &kp F12
&bt BT_PRV  &bt BT_NXT    &trans        &trans        &trans        &trans                          &kp K_MUTE  &kp C_VOLUME_DOWN  &kp C_VOLUME_UP  &trans  &trans   &trans
&trans      &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4  &trans    &trans  &trans      &kp C_PREVIOUS     &kp C_NEXT       &trans  &trans   &trans
                                        &trans        &trans        &trans        &trans    &trans  &trans      &trans             &trans
            >;

            label = "SYS";
        };

        hot_key {
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans                                           &trans         &trans  &trans  &trans  &trans  &snippet_tool
&trans  &trans  &trans  &trans  &trans  &vs_fold                                         &trans         &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &vs_unfold                                       &trans         &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans      &vs_left_editor    &vs_right_editor  &trans         &trans  &trans  &trans  &trans  &trans
                        &trans  &trans  &trans      &trans             &trans            &clip_history  &trans  &trans
            >;

            label = "HOTKY";
        };

        game {
            bindings = <
&kp M      &kp N1     &kp N2  &kp N3   &kp N4  &kp N5                       &trans  &trans  &trans  &trans  &trans  &to 0
&kp TAB    &none      &kp Q   &kp W    &kp E   &kp R                        &trans  &trans  &trans  &trans  &trans  &trans
&kp LSHFT  &none      &kp A   &kp S    &kp D   &kp F                        &trans  &trans  &trans  &trans  &trans  &trans
&kp LCTRL  &kp LSHFT  &kp Z   &kp X    &kp C   &kp V   &kp G        &trans  &trans  &trans  &trans  &trans  &trans  &trans
                              &kp ESC  &trans  &kp T   &kp SPACE    &trans  &trans  &trans  &trans
            >;

            label = "GMR";
        };
    };

    conditional_layers {
        compatible = "zmk,conditional-layers";

        sys {
            if-layers = <1 2>;
            then-layer = <3>;
        };
    };
};
